# Auth Admin
ADMIN_USER=admin
ADMIN_PASSWORD_HASH=$2a$10$example_hash_here
JWT_SECRET=your-random-secret-here

# Database (auto-provisioned by Vercel Marketplace)
DATABASE_URL=postgresql://user:pass@host/db

# Storage (auto-provisioned)
BLOB_READ_WRITE_TOKEN=vercel_blob_token

# AI (OIDC via vercel env pull)
VERCEL_OIDC_TOKEN=auto

# Google TTS
GOOGLE_TTS_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_TTS_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----

# Pixabay
PIXABAY_API_KEY=your-pixabay-key

# Email (auto-provisioned)
RESEND_API_KEY=re_xxxxx

# Cron
CRON_SECRET=your-cron-secret
